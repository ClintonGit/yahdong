generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  owner
  admin
  member
}

enum ProjectRole {
  owner
  member
  viewer
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  avatar        String?
  createdAt     DateTime  @default(now())

  orgMembers      OrgMember[]
  projectMembers  ProjectMember[]
  taskAssignments TaskAssignee[]
  createdTasks    Task[]          @relation("creator")
  comments        Comment[]
  refreshTokens   RefreshToken[]
  notifications   Notification[]
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])
}

model Organization {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  createdAt DateTime    @default(now())
  members   OrgMember[]
  projects  Project[]
}

model OrgMember {
  orgId  String
  userId String
  role   OrgRole @default(member)
  org    Organization @relation(fields: [orgId], references: [id])
  user   User         @relation(fields: [userId], references: [id])
  @@id([orgId, userId])
}

model Project {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  slug        String
  description String?
  color       String?
  coverImage  String?
  isPublic    Boolean   @default(false)
  shareToken  String?   @unique
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  org         Organization    @relation(fields: [orgId], references: [id])
  members     ProjectMember[]
  statuses    TaskStatus[]
  tasks       Task[]
  invites     ProjectInvite[]
  labels      Label[]
  @@unique([orgId, slug])
}

model ProjectMember {
  projectId String
  userId    String
  role      ProjectRole @default(member)
  starred   Boolean     @default(false)
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])
  @@id([projectId, userId])
}

model ProjectInvite {
  id        String      @id @default(cuid())
  projectId String
  token     String      @unique
  email     String?
  role      ProjectRole @default(member)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime    @default(now())
  project   Project @relation(fields: [projectId], references: [id])
}

model TaskStatus {
  id        String  @id @default(cuid())
  projectId String
  name      String
  color     String
  order     Float
  project   Project @relation(fields: [projectId], references: [id])
  tasks     Task[]
}

model Task {
  id             String        @id @default(cuid())
  projectId      String
  title          String
  description    String?
  statusId       String
  priority       TaskPriority  @default(medium)
  sprintId       String?
  dueDate        DateTime?
  coverImage     String?
  coverColor     String?
  order          Float
  createdBy      String
  createdAt      DateTime      @default(now())
  project        Project       @relation(fields: [projectId], references: [id])
  status         TaskStatus    @relation(fields: [statusId], references: [id])
  creator        User          @relation("creator", fields: [createdBy], references: [id])
  comments       Comment[]
  labels         TaskLabel[]
  checklistItems ChecklistItem[]
  assignees      TaskAssignee[]
  notifications  Notification[]
}

model Label {
  id        String      @id @default(cuid())
  projectId String
  name      String
  color     String
  project   Project     @relation(fields: [projectId], references: [id])
  tasks     TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task  @relation(fields: [taskId], references: [id])
  label   Label @relation(fields: [labelId], references: [id])
  @@id([taskId, labelId])
}

model ChecklistItem {
  id        String   @id @default(cuid())
  taskId    String
  text      String
  checked   Boolean  @default(false)
  order     Float
  createdAt DateTime @default(now())
  task      Task @relation(fields: [taskId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  body      String
  imageUrl  String?
  createdAt DateTime @default(now())
  task      Task @relation(fields: [taskId], references: [id])
  user      User @relation(fields: [userId], references: [id])
}

model TaskAssignee {
  taskId  String
  userId  String
  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@id([taskId, userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  taskId    String
  commentId String?
  type      String    @default("mention")
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
