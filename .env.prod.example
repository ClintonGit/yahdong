# ── Database (external PostgreSQL) ───────────────────────────────────────────
# URL-encode special chars in password: ? → %3F, $ → %24, ] → %5D, % → %25
DATABASE_URL=postgresql://<user>:<encoded-password>@168.144.128.246:5432/yahdong

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
